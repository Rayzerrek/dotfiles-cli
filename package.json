{
  "name": "@rayzerrek/dot-cli",
  "version": "1.0.15",
  "description": "Lightweight, cross-platform CLI manager to keep configurations (dotfiles) in sync",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "bin": {
    "dot": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rayzerrek/dot-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Rayzerrek/dot-cli/issues"
  },
  "homepage": "https://github.com/Rayzerrek/dot-cli#readme",
  "scripts": {
    "build": "bun build ./src/index.ts --target=node --outfile=./dist/index.js && tsc --emitDeclarationOnly",
    "compile": "bun build ./src/index.ts --compile --outfile=./dist/dot.exe",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.5"
  }
}
