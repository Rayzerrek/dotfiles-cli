{
  "dotfilesDir": "~/dotfiles",
  "links": [
    {
      "name": ".agents",
      "systemPath": {
        "windows": "~/.agents",
        "macos": "~/.agents",
        "linux": "~/.agents"
      }
    },
    {
      "name": "nvim",
      "systemPath": {
        "windows": "~/AppData/Local/nvim",
        "macos": "~/.config/nvim",
        "linux": "~/.config/nvim"
      }
    },
    {
      "name": ".vscode",
      "systemPath": {
        "windows": "~/AppData/Roaming/Code/User",
        "macos": "~/Library/Application Support/Code/User",
        "linux": "~/.config/Code/User"
      }
    }
  ]
}
